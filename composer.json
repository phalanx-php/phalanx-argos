{
    "name": "phalanx/argos",
    "description": "Network discovery, probing, and device management for Phalanx",
    "license": "MIT",
    "type": "library",
    "keywords": ["network", "discovery", "mdns", "ssdp", "wol", "ping", "scan", "async", "reactphp"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-argos",
    "require": {
        "php": "^8.4",
        "phalanx/aegis": "^0.5",
        "mlocati/ip-lib": "^1.22",
        "react/datagram": "^1.10",
        "react/async": "^4.3",
        "react/event-loop": "^1.5",
        "react/promise": "^3.2",
        "react/child-process": "^0.6",
        "react/socket": "^1.16",
        "react/dns": "^1.13"
    },
    "suggest": {
        "clue/multicast-react": "Required for mDNS and SSDP discovery (multicast UDP)",
        "clue/mdns-react": "Required for mDNS zeroconf discovery",
        "clue/ssdp-react": "Required for SSDP/UPnP device discovery"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Argos\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Argos\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.5-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
